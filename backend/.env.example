# Supabase
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct PostgreSQL connection (from Supabase Dashboard → Settings → Database → Connection string → Transaction pooler)
DATABASE_URL=postgresql+asyncpg://postgres.xxxxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# CORS
FRONTEND_URL=http://localhost:5173
